---
interface Props {
	title: string;
	date: string;
	company: string;
	description: string;
	icon?: string;
}

const { title, date, company, description, icon } = Astro.props;
---

<div class="timeline-item">
	{icon && <div class="timeline-icon"><img src={icon} alt={company} /></div>}
	<div class="timeline-dot"></div>
	<div class="timeline-content">
		<div class="timeline-header">
			<h3>{title}</h3>
			<span class="timeline-date">{date}</span>
		</div>
		<p class="timeline-company">{company}</p>
		<p class="timeline-description">{description}</p>
	</div>
</div>

<style>
	.timeline-item {
		position: relative;
		padding-bottom: 2.5rem;
		transform: translateY(100vh);
		transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-item.fade-in {
		opacity: 1;
		transform: translateY(0);
	}

	.timeline-dot {
		position: absolute;
		left: -3.6rem;
		top: 35%;
		margin-top: -0.35rem;
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
		border: none;
		background: rgba(255, 255, 255, 0.2);
		z-index: 1;
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}

	.timeline-dot::before,
	.timeline-dot::after {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 2px;
		height: 60px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.timeline-dot::before {
		bottom: 100%;
		background: linear-gradient(to bottom,
			transparent 0%,
			rgba(255, 255, 255, 0.4) 40%,
			rgba(255, 255, 255, 0.8) 75%,
			#fff 100%
		);
	}

	.timeline-dot::after {
		top: 100%;
		background: linear-gradient(to top,
			transparent 0%,
			rgba(255, 255, 255, 0.4) 40%,
			rgba(255, 255, 255, 0.8) 75%,
			#fff 100%
		);
	}

	.timeline-item:hover .timeline-dot {
		background: #fff;
		box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.6), 0 0 16px 4px rgba(255, 255, 255, 0.3);
	}

	.timeline-item:hover .timeline-dot::before,
	.timeline-item:hover .timeline-dot::after {
		opacity: 1;
	}

	.timeline-content {
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		border: 1px solid transparent;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.timeline-item:hover .timeline-content {
		background: rgba(255, 255, 255, 0.07);
		border-color: rgba(255, 255, 255, 0.15);
	}

	.timeline-icon {
		position: absolute;
		left: -7.5rem;
		top: 35%;
		margin-top: -1.5rem;
		width: 3rem;
		height: 3rem;
	}

	.timeline-icon img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
	}

	.timeline-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 0.25rem;
	}

	.timeline-header h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin: 0;
	}

	.timeline-date {
		font-size: 0.95rem;
		opacity: 0.5;
		white-space: nowrap;
	}

	.timeline-company {
		font-size: 1.05rem;
		opacity: 0.6;
		margin-bottom: 0.5rem;
	}

	.timeline-description {
		font-size: 1.1rem;
		line-height: 1.6;
		opacity: 0.75;
		margin: 0;
	}
</style>