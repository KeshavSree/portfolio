---
import Analytics from '@vercel/analytics/astro';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Keshav Sreekantham</title>
		<!-- Open Graph / social preview -->
		<meta property="og:title" content="Portfolio Website" />
		<meta property="og:description" content="Keshav Sreekantham" />
		<meta property="og:image" content="https://keshavsreekantham.com/og-image.png" />
		<meta property="og:url" content="https://keshavsreekantham.com" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://keshavsreekantham.com/og-image.png" />
	</head>
	<body>
		<slot />
		<Analytics />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		background: #000;
		color: #fff;
		font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono",
			"Courier New", monospace;
	}
</style>
